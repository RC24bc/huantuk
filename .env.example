# Huantuk — Patient Atlas
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Required for live Opus 4.7 reasoning. Without this, the app falls back to
# the deterministic demo synthesis + mock-up Drug Discovery results.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — model override. Defaults to claude-opus-4-7 in code.
# ANTHROPIC_MODEL=claude-opus-4-7
